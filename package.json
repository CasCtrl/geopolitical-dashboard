    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --reporter=line",
    "test:e2e:smoke:ci": "playwright test e2e/smoke.spec.ts --reporter=line",
    "playwright:install": "playwright install --with-deps chromium",
    "perf:budget": "node scripts/check-bundle-budget.mjs",
    "ci": "npm run lint && npm run test:ci && npm run build",
    "governance:check": "node scripts/governance-preflight.mjs"
