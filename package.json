{
  "name": "geopolitical-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--max_old_space_size=4096 vite",
    "dev:server": "NODE_OPTIONS=--max_old_space_size=2048 node server/server.js",
    "dev:full": "node scripts/dev-full.mjs",
    "build": "tsc && vite build",
