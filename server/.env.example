# Server runtime
SERVER_PORT=5001
NODE_ENV=development
APP_VERSION=1.1

# Database connection
DB_SERVER=localhost
DB_DATABASE=geopolitical_dashboard
DB_USER=sa
# Required when DB access is enabled (DB_INIT_ENABLED=true, DB_CONNECT_STRICT=true, or production).
DB_PASSWORD=
DB_PORT=1433

# Startup behavior
# When true, server startup fails if SQL connection cannot be established
DB_CONNECT_STRICT=false
# When true, schema/data initialization runs on boot
DB_INIT_ENABLED=true

# API security
AUTH_REQUIRED=false
# Required when AUTH_REQUIRED=true. Must not remain 'change-me' in production.
API_TOKEN=change-me
ADMIN_ROLE=admin

# CORS and rate limiting
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003
RATE_LIMIT_MAX=300
EXPENSIVE_READ_WINDOW_MS=60000
EXPENSIVE_READ_MAX=30
EXPENSIVE_WRITE_WINDOW_MS=900000
EXPENSIVE_WRITE_MAX=20
ADMIN_RATE_LIMIT_WINDOW_MS=60000
ADMIN_RATE_LIMIT_MAX=60
AUDIT_TRAIL_MAX_ENTRIES=1000
AUDIT_SINK_ENABLED=true
AUDIT_SINK_DIR=./server/audit
AUDIT_SINK_MAX_FILES=14

# Lightweight observability thresholds (used by /api/admin/alerts)
OBS_MIN_REQUESTS=20
OBS_ERROR_RATE_THRESHOLD_PCT=5
OBS_P95_LATENCY_THRESHOLD_MS=800
OBS_DB_HEALTH_MIN_PCT=99
OBS_NEWS_INGESTION_MIN_SUCCESS_PCT=95
OBS_FRONTEND_CRASH_MAX_PER_1K=2
INCIDENT_MAX_ENTRIES=500
# Optional external incident destination (PagerDuty/EventBridge/webhook relay)
INCIDENT_WEBHOOK_URL=

# Integration and API connector settings
INTEGRATION_WEBHOOK_URL=
BLOOMBERG_PORTFOLIO_API_URL=
BLOOMBERG_API_TOKEN=
PORTFOLIO_INTEGRATION_TIMEOUT_MS=10000
PIPELINE_SOURCE_URLS=
PIPELINE_SOURCE_AUTH_TOKEN=

# Compliance and policy metadata
PRIVACY_POLICY_URL=
TERMS_OF_USE_URL=
DATA_RETENTION_DAYS=90
