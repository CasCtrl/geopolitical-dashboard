# Server runtime
SERVER_PORT=5001
NODE_ENV=development
APP_VERSION=1.1

# Database connection
DB_SERVER=localhost
DB_DATABASE=geopolitical_dashboard
DB_USER=sa
DB_PASSWORD=YourPassword123!
DB_PORT=1433

# Startup behavior
# When true, server startup fails if SQL connection cannot be established
DB_CONNECT_STRICT=false
# When true, schema/data initialization runs on boot
DB_INIT_ENABLED=true

# API security
AUTH_REQUIRED=false
# Required when AUTH_REQUIRED=true
API_TOKEN=change-me
ADMIN_ROLE=admin

# CORS and rate limiting
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003
RATE_LIMIT_MAX=300
