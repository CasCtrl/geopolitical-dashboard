# Copy this file to .github/deploy/deploy.<environment>.env and fill values.
# Example:
#   cp .github/deploy/deploy.env.example .github/deploy/deploy.staging.env
#   cp .github/deploy/deploy.env.example .github/deploy/deploy.production.env

# Required target selector
ENVIRONMENT_NAME=staging

# Required GitHub Environment secrets
DEPLOY_HOST=
DEPLOY_USER=
DEPLOY_SSH_KEY=

# Optional secret (for auth-protected health endpoints)
DEPLOY_HEALTHCHECK_HEADER=

# Required GitHub Environment vars
DEPLOY_PATH=
DEPLOY_HEALTHCHECK_URL=

# Optional GitHub Environment vars
DEPLOY_PORT=22
DEPLOY_RESTART_COMMAND=systemctl restart geopolitical-dashboard
DEPLOY_HEALTH_TIMEOUT_SECONDS=120
